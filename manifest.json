{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "1.0",
  "author": "4WoofGrrrr",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "trash-incinerator@localmotive.com",
      "strict_min_version": "128.0"
    }
  },
  "browser_action": {
    "type": "button",
    "default_title": "Trash Incinerator",
    "default_label": "Incinerate Trash",
    "default_icon": "images/icons/burn_trash_outlined_32x32.png"
  },
  "permissions": [
    "accountsFolders",
    "accountsRead",
    "management",
    "menus",
    "messagesDelete",
    "messagesRead",
    "storage"
  ],
  "background": {
    "page": "trash-incinerator-background.html"
  },
  "options_ui": {
    "page": "optionsUI/optionsUI.html",
    "browser_style": false,
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [ "https://*/*" ],
      "js": [
        "./modules/utilities.js"
      ]
    }
  ],
  "icons": {
    "64": "images/icons/burn_trash_outlined_64x64.png",
    "32": "images/icons/burn_trash_outlined_32x32.png",
    "24": "images/icons/burn_trash_outlined_24x24.png",
    "16": "images/icons/burn_trash_outlined_16x16.png"
  }
}
